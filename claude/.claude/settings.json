{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(curl * localhost:8020*)",
      "Bash(curl * BypassId * localhost:8020*)",
      "Read",
      "Grep",
      "Write(/home/daphen/**)",
      "Edit(/home/daphen/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)"
    ],
    "deny": [],
    "ask": []
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/daphen/dotfiles/nvim/.config/nvim/lua/ai-tracker/preview-hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/daphen/.claude/hooks/ai-tracker.js"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "graphite-workflow@lovable-internal": true
  },
  "alwaysThinkingEnabled": true,
  "theme": "light-ansi",
  "skipAutoPermissionPrompt": true
}
