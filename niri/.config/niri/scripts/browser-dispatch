#!/usr/bin/env bash
# Routes URLs to the correct Vivaldi profile (personal or work).
# Uses URL pattern matching; falls back to personal profile.
#
# To revert to qutebrowser: comment the Vivaldi block, uncomment the qute block.

URL="$1"

# ── URL routing rules ─────────────────────────────────────────────────────────

is_personal_url() {
    [[ "$1" =~ ^https?://(www\.|m\.|music\.)?youtube\.com ]] || \
    [[ "$1" =~ ^https?://youtu\.be ]]
}

is_work_url() {
    [[ "$1" =~ lovable ]]
}

# ── Profile selection ─────────────────────────────────────────────────────────

PROFILE="personal"
if is_work_url "$URL"; then PROFILE="work"; fi
if is_personal_url "$URL"; then PROFILE="personal"; fi

# ── Vivaldi dispatch ──────────────────────────────────────────────────────────

if [[ "$PROFILE" == "work" ]]; then
    exec /run/current-system/sw/bin/vivaldi --profile-directory="Profile 2" "$URL"
else
    exec /run/current-system/sw/bin/vivaldi --profile-directory=Default "$URL"
fi

