#!/usr/bin/env bash
# Launch or focus the personal-profile browser window. Tracks a single
# personal-profile window and re-focuses it on subsequent presses.
# Browser binary, profile name, and class are read from browser-config.sh
# so this script is browser-agnostic.

set -u

source "$(dirname "$0")/browser-config.sh"

PERSONAL_ID_FILE="/tmp/${BROWSER_CLASS_PERSONAL}-window-id"
WORK_ID_FILE="/tmp/${BROWSER_CLASS_WORK}-window-id"

# If we have a stored window ID that still exists as a personal/work
# browser window, focus it.
if [[ -f "$PERSONAL_ID_FILE" ]]; then
    stored_id=$(cat "$PERSONAL_ID_FILE")
    exists=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print('yes' if any(str(w['id']) == '$stored_id' and w.get('app_id') in ('$BROWSER_CLASS_PERSONAL', '$BROWSER_CLASS_WORK') for w in windows) else 'no')
" 2>/dev/null)
    if [[ "$exists" == "yes" ]]; then
        niri msg action focus-window --id "$stored_id"
        exit 0
    fi
fi

# Snapshot existing browser IDs before launch (exclude known work window)
work_id=$(cat "$WORK_ID_FILE" 2>/dev/null || echo "")
before=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print(' '.join(str(w['id']) for w in windows if w.get('app_id') in ('$BROWSER_CLASS_PERSONAL', '$BROWSER_CLASS_WORK')))
" 2>/dev/null)

# Launch personal profile. --class sets the Wayland app-id so window-rules
# can distinguish personal vs work even though both come from the same binary.
"$BROWSER_BIN" \
    "${BROWSER_FLAGS[@]}" \
    --user-data-dir="$BROWSER_USER_DATA_PERSONAL" \
    --profile-directory="$BROWSER_PROFILE" \
    --class="$BROWSER_CLASS_PERSONAL" &

# Poll for the new browser window (up to 5s), excluding work profile
for i in $(seq 1 25); do
    sleep 0.2
    new_id=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
before_ids = set('$before'.split())
work_id = '$work_id'
for w in windows:
    if w.get('app_id') in ('$BROWSER_CLASS_PERSONAL', '$BROWSER_CLASS_WORK') and str(w['id']) not in before_ids and str(w['id']) != work_id:
        print(w['id'])
        break
" 2>/dev/null)
    if [[ -n "$new_id" ]]; then
        echo "$new_id" > "$PERSONAL_ID_FILE"
        # Pin to the named "chat" workspace.
        niri msg action move-window-to-workspace \
            --window-id "$new_id" --focus false chat 2>/dev/null || true
        break
    fi
done
