#!/usr/bin/env bash
# Launch or focus the work-profile browser window. Tracks a single
# work-profile window and re-focuses it on subsequent presses.
# Browser binary, profile name, and class are read from browser-config.sh
# so this script is browser-agnostic.
#
# First-time use: most Chromium-derived browsers create the configured
# profile directory automatically when --profile-directory references
# a name that doesn't exist yet. After it exists you can rename the
# profile via the avatar menu without changing the directory name.

set -u

source "$(dirname "$0")/browser-config.sh"

WORK_ID_FILE="/tmp/${BROWSER_CLASS_WORK}-window-id"
ACTIVE_FILE="$HOME/.local/state/wt-stacks/ws/active"

# Reuse the stored work window only if it still exists AND lives on a
# valid workspace — either the currently-active lovable stack, or a
# non-lovable workspace (legacy / no-worktree case). Avoids yanking
# niri to an inactive worktree when the user wanted a window here.
if [[ -f "$WORK_ID_FILE" ]]; then
    stored_id=$(cat "$WORK_ID_FILE")
    active_stack=$(cat "$ACTIVE_FILE" 2>/dev/null || true)
    valid=$(STORED="$stored_id" ACTIVE="$active_stack" \
        PERSONAL="$BROWSER_CLASS_PERSONAL" WORK="$BROWSER_CLASS_WORK" \
        python3 -c '
import json, os, subprocess, sys
stored = int(os.environ["STORED"]) if os.environ["STORED"].isdigit() else None
active = os.environ.get("ACTIVE") or None
classes = (os.environ["PERSONAL"], os.environ["WORK"])
windows = json.loads(subprocess.run(["niri", "msg", "--json", "windows"],
                    capture_output=True, text=True).stdout)
w = next((x for x in windows
          if x.get("id") == stored and x.get("app_id") in classes), None)
if w is None:
    print("no"); sys.exit()
workspaces = json.loads(subprocess.run(["niri", "msg", "--json", "workspaces"],
                       capture_output=True, text=True).stdout)
ws_name = next((s.get("name") for s in workspaces
                if s.get("id") == w.get("workspace_id")), "") or ""
if ws_name == active:
    print("yes")
elif ws_name.startswith("lovable-") and ws_name != "lovable":
    print("no")  # an inactive lovable stack
else:
    print("yes")  # non-lovable workspace, free to focus
' 2>/dev/null)
    if [[ "$valid" == "yes" ]]; then
        niri msg action focus-window --id "$stored_id"
        exit 0
    fi
fi

# Snapshot existing browser IDs before launch
before=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print(' '.join(str(w['id']) for w in windows if w.get('app_id') in ('$BROWSER_CLASS_PERSONAL', '$BROWSER_CLASS_WORK')))
" 2>/dev/null)

# Launch work profile
"$BROWSER_BIN" \
    "${BROWSER_FLAGS[@]}" \
    --user-data-dir="$BROWSER_USER_DATA_WORK" \
    --profile-directory="$BROWSER_PROFILE" \
    --class="$BROWSER_CLASS_WORK" &

# Poll for the new browser window (up to 5s)
for i in $(seq 1 25); do
    sleep 0.2
    new_id=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
before_ids = set('$before'.split())
for w in windows:
    if w.get('app_id') in ('$BROWSER_CLASS_PERSONAL', '$BROWSER_CLASS_WORK') and str(w['id']) not in before_ids:
        print(w['id'])
        break
" 2>/dev/null)
    if [[ -n "$new_id" ]]; then
        echo "$new_id" > "$WORK_ID_FILE"
        break
    fi
done
