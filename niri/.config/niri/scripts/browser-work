#!/usr/bin/env bash
# Launch or focus the work-profile browser window. Tracks a single
# work-profile window and re-focuses it on subsequent presses.
# Browser binary, profile name, and class are read from browser-config.sh
# so this script is browser-agnostic.
#
# First-time use: most Chromium-derived browsers create the configured
# profile directory automatically when --profile-directory references
# a name that doesn't exist yet. After it exists you can rename the
# profile via the avatar menu without changing the directory name.

set -u

source "$(dirname "$0")/browser-config.sh"

WORK_ID_FILE="/tmp/${BROWSER_CLASS_WORK}-window-id"

# If we have a stored window ID that still exists, focus it
if [[ -f "$WORK_ID_FILE" ]]; then
    stored_id=$(cat "$WORK_ID_FILE")
    exists=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print('yes' if any(str(w['id']) == '$stored_id' and w.get('app_id') in ('$BROWSER_CLASS_PERSONAL', '$BROWSER_CLASS_WORK') for w in windows) else 'no')
" 2>/dev/null)
    if [[ "$exists" == "yes" ]]; then
        niri msg action focus-window --id "$stored_id"
        exit 0
    fi
fi

# Snapshot existing browser IDs before launch
before=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print(' '.join(str(w['id']) for w in windows if w.get('app_id') in ('$BROWSER_CLASS_PERSONAL', '$BROWSER_CLASS_WORK')))
" 2>/dev/null)

# Launch work profile
"$BROWSER_BIN" \
    "${BROWSER_FLAGS[@]}" \
    --user-data-dir="$BROWSER_USER_DATA_WORK" \
    --class="$BROWSER_CLASS_WORK" &

# Poll for the new browser window (up to 5s)
for i in $(seq 1 25); do
    sleep 0.2
    new_id=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
before_ids = set('$before'.split())
for w in windows:
    if w.get('app_id') in ('$BROWSER_CLASS_PERSONAL', '$BROWSER_CLASS_WORK') and str(w['id']) not in before_ids:
        print(w['id'])
        break
" 2>/dev/null)
    if [[ -n "$new_id" ]]; then
        echo "$new_id" > "$WORK_ID_FILE"
        break
    fi
done
