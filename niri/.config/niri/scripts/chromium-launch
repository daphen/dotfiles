#!/usr/bin/env bash
# Launch the personal-profile browser. Always uses AMD iGPU — PRIME offload
# adds too much overhead for browsers. Games use NVIDIA via programs.steam.
# Browser binary and profile name come from browser-config.sh.

set -u

source "$(dirname "$0")/browser-config.sh"

exec "$BROWSER_BIN" \
    --profile-directory="$BROWSER_PROFILE_PERSONAL" \
    --class="$BROWSER_CLASS_PERSONAL" "$@"
