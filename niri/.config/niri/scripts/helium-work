#!/usr/bin/env bash
# Launch or focus Helium work profile ("Profile 2").
# Store the window id on launch, focus it next time.
#
# First-time use: Helium creates "Profile 2" automatically when it sees the
# --profile-directory flag. After it exists you can rename it to "Work" via
# the avatar menu without changing the directory name (the dir name stays
# "Profile 2" — only the display name changes).

WORK_ID_FILE="/tmp/helium-work-window-id"

# If we have a stored window ID that still exists, focus it
if [[ -f "$WORK_ID_FILE" ]]; then
    stored_id=$(cat "$WORK_ID_FILE")
    exists=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print('yes' if any(str(w['id']) == '$stored_id' and w.get('app_id') in ('helium-personal', 'helium-work') for w in windows) else 'no')
" 2>/dev/null)
    if [[ "$exists" == "yes" ]]; then
        niri msg action focus-window --id "$stored_id"
        exit 0
    fi
fi

# Snapshot existing helium IDs before launch
before=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print(' '.join(str(w['id']) for w in windows if w.get('app_id') in ('helium-personal', 'helium-work')))
" 2>/dev/null)

# Launch work profile
/etc/profiles/per-user/daphen/bin/helium \
    --profile-directory="Profile 2" \
    --class=helium-work &

# Poll for the new helium window (up to 5s)
for i in $(seq 1 25); do
    sleep 0.2
    new_id=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
before_ids = set('$before'.split())
for w in windows:
    if w.get('app_id') in ('helium-personal', 'helium-work') and str(w['id']) not in before_ids:
        print(w['id'])
        break
" 2>/dev/null)
    if [[ -n "$new_id" ]]; then
        echo "$new_id" > "$WORK_ID_FILE"
        break
    fi
done
