#!/usr/bin/env bash
# Deactivate the active Wi-Fi connection and bring it back up.
# Mirrors what nmtui does when you toggle a connection — leaves the radio on
# and just re-establishes the connection (DHCP, routes, supplicant).

set -u

con=$(nmcli -t -f NAME,TYPE connection show --active \
    | awk -F: '$2=="802-11-wireless"{print $1; exit}')

if [ -z "${con:-}" ]; then
    notify-send -u critical "Wi-Fi" "No active Wi-Fi connection to restart"
    exit 1
fi

notify-send "Wi-Fi" "Restarting $con…"

if nmcli connection down "$con" && nmcli connection up "$con"; then
    notify-send "Wi-Fi" "Reconnected to $con"
else
    notify-send -u critical "Wi-Fi" "Failed to reconnect to $con"
    exit 1
fi
