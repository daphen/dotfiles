#!/usr/bin/env bash
# Rofi picker over open lovable worktrees.
#
#   Enter   → focus the selected worktree's workspace
#   Ctrl+W  → close the worktree (kills windows, devenv kill, wt remove).
#             Confirmed via a second rofi prompt.

set -uo pipefail

SCRIPT_DIR="$HOME/.config/niri/scripts"
LOVABLE_ICON="$HOME/.local/share/icons/hicolor/512x512/apps/lovable.png"

mapfile -t names < <(niri msg --json workspaces 2>/dev/null \
    | jq -r '.[]
        | select(.name
                 and (.name | startswith("lovable-"))
                 and .name != "lovable"
                 and .name != "lovable-deps")
        | .name
        | sub("^lovable-"; "")')

if [ "${#names[@]}" -eq 0 ]; then
    notify-send -a "lovable" "No open worktrees" \
        "Use Lovable: New Worktree to create one." 2>/dev/null || true
    exit 0
fi

# rofi -dmenu icon protocol: each entry can carry metadata after a
# NUL byte. Format: "<display>\0icon\x1f<path>". With -show-icons,
# rofi renders the lovable.png icon next to each name — same image
# the waybar worktree pill uses.
entries=()
for n in "${names[@]}"; do
    entries+=("$(printf '%s\0icon\x1f%s' "$n" "$LOVABLE_ICON")")
done

# kb-custom-1 (Ctrl+W) → exit 10. Default Enter → exit 0. Esc → exit 1.
# Rofi binds Control+w to kb-clear-line by default; unbind it
# (-kb-clear-line "") before reassigning.
selected=$(printf '%s\n' "${entries[@]}" | rofi -dmenu -i \
    -show-icons \
    -p "worktree" \
    -theme-str 'window {width: 30em;}' \
    -mesg "Enter: focus    Ctrl+W: close worktree" \
    -kb-clear-line "" \
    -kb-custom-1 "Control+w")
rc=$?

# rofi returns just the display string (the part before the NUL).
name="$selected"

if [ -z "$name" ]; then
    exit 0
fi

case "$rc" in
    0)
        niri msg action focus-workspace "lovable-$name"
        ;;
    10)
        confirm=$(printf 'no\nyes\n' | rofi -dmenu -i \
            -p "Close '$name'?" \
            -theme-str 'window {width: 24em;}')
        if [ "$confirm" = "yes" ]; then
            "$SCRIPT_DIR/ws-close-worktree" "$name"
        fi
        ;;
esac
