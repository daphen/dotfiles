#!/usr/bin/env bash
# Rofi picker over open lovable worktrees.
#
#   Enter   → focus the selected worktree's workspace
#   Ctrl+W  → close the worktree session: kills windows + devenv kill +
#             unnames the workspace, but keeps the on-disk worktree dir
#             so it can be reopened later via Super+Ctrl+T.
#             Confirmed via a second rofi prompt.
#
# Order: most-recently visited first (read from ws-tracker's recency
# state). The currently-active worktree is highlighted in bold.

set -uo pipefail

SCRIPT_DIR="$HOME/.config/niri/scripts"
LOVABLE_ICON="$HOME/.local/share/icons/hicolor/256x256/apps/lovable-square.png"
RECENCY_FILE="$HOME/.local/state/wt-stacks/ws/recency"
ACTIVE_FILE="$HOME/.local/state/wt-stacks/ws/active"

# Existing lovable-<name> workspaces (stripped names).
mapfile -t names < <(niri msg --json workspaces 2>/dev/null \
    | jq -r '.[]
        | select(.name
                 and (.name | startswith("lovable-"))
                 and .name != "lovable"
                 and .name != "lovable-main")
        | .name
        | sub("^lovable-"; "")')

if [ "${#names[@]}" -eq 0 ]; then
    notify-send -a "lovable" "No open worktrees" \
        "Use Lovable: New Worktree to create one." 2>/dev/null || true
    exit 0
fi

# Recency-ordered names from ws-tracker (full lovable-<name>, most
# recent first), stripped to bare names.
recency_names=()
if [ -f "$RECENCY_FILE" ]; then
    mapfile -t recency_names < <(jq -r '.[]?' "$RECENCY_FILE" 2>/dev/null \
        | sed 's|^lovable-||')
fi

# Active worktree (bare name).
active_name=""
if [ -f "$ACTIVE_FILE" ]; then
    active_name=$(sed 's|^lovable-||' "$ACTIVE_FILE" 2>/dev/null | tr -d '\n')
fi

# Build display order: recency first (filtered to currently-existing
# worktrees, deduped), then any worktree that isn't in recency yet
# (e.g. just-created) appended at the end.
declare -A name_present
for n in "${names[@]}"; do
    name_present["$n"]=1
done

declare -A seen
ordered=()
for n in "${recency_names[@]}"; do
    if [ "${name_present[$n]:-}" = "1" ] && [ -z "${seen[$n]:-}" ]; then
        ordered+=("$n")
        seen[$n]=1
    fi
done
for n in "${names[@]}"; do
    if [ -z "${seen[$n]:-}" ]; then
        ordered+=("$n")
        seen[$n]=1
    fi
done

# Active worktree gets the orange accent so it reads as "you are here".
rows=()
for n in "${ordered[@]}"; do
    if [ "$n" = "$active_name" ]; then
        rows+=("<span foreground='#FF570D'>$n</span>")
    else
        rows+=("$n")
    fi
done

# Lovable heart next to the "worktree" prompt. `size:` constrains the
# widget on both axes — width/height alone produced a tall sliver.
ICON_THEME='
inputbar { children: [ icon-prompt, entry ]; }
icon-prompt {
    expand:           false;
    background-image: url("'"$LOVABLE_ICON"'", both);
    size:             1.2em;
    margin:           0 0.5em 0 0;
}
entry {
    placeholder:      "worktrees";
}
'

# -format i returns the index of the selected row in our input list,
# which lets us look up the bare name without parsing markup.
selected_idx=$(printf '%s\n' "${rows[@]}" | rofi -dmenu -i \
    -sync \
    -format i \
    -markup-rows \
    -p "worktree" \
    -theme-str "$ICON_THEME" \
    -mesg "Enter: focus    Ctrl+W: close worktree" \
    -kb-clear-line "" \
    -kb-custom-1 "Control+w")
rc=$?

if [ -z "$selected_idx" ]; then
    exit 0
fi
name="${ordered[$selected_idx]}"

case "$rc" in
    0)
        niri msg action focus-workspace "lovable-$name"
        ;;
    10)
        confirm=$(printf 'no\nyes\n' | rofi -dmenu -i \
            -p "Close '$name'?" \
            -theme-str 'window {width: 24em;}')
        if [ "$confirm" = "yes" ]; then
            "$SCRIPT_DIR/ws-close-worktree" "$name"
        fi
        ;;
esac
