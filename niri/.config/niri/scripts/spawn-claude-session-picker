#!/usr/bin/env bash
# Pick a recent Claude Code session with fzf.
#
# Default: cd to the session's original cwd and exec `claude --resume <id>`.
# --id-only: just print the session id (no claude exec, no cd) — used by
#            createwt/startwt to pick a session ID for forking or resuming
#            inside the new worktree path.

ID_ONLY=0
if [[ "${1:-}" == "--id-only" ]]; then
    ID_ONLY=1
fi

SESSIONS_DIR="$HOME/.claude/projects"

if [ ! -d "$SESSIONS_DIR" ]; then
    echo "No sessions found"
    sleep 2
    exit 1
fi

# Build entries. Each line has a hidden prefix: session_id:cwd:jsonl_path<NUL>display_text
# We use NUL as separator since it can't appear in text, but fzf doesn't support that.
# Instead: prefix each line with "IDX " and keep a parallel array in a temp file.

meta_file=$(mktemp)
display_file=$(mktemp)
trap 'rm -f "$meta_file" "$display_file"' EXIT

SESSIONS_DIR="$SESSIONS_DIR" META_FILE="$meta_file" DISPLAY_FILE="$display_file" python3 <<'PY'
import json, os, sys
from datetime import datetime, timezone
from pathlib import Path

sessions_dir = Path(os.environ['SESSIONS_DIR'])
meta_out = open(os.environ['META_FILE'], 'w')
display_out = open(os.environ['DISPLAY_FILE'], 'w')

now = datetime.now(timezone.utc)

def fmt_ago(ts):
    if not ts:
        return '-'
    try:
        dt = datetime.fromisoformat(ts.replace('Z', '+00:00'))
        secs = int((now - dt).total_seconds())
        if secs < 3600: return f'{secs // 60}m ago'
        if secs < 86400: return f'{secs // 3600}h ago'
        if secs < 604800: return f'{secs // 86400}d ago'
        return dt.strftime('%b %d')
    except Exception:
        return '-'

def first_user_text(obj):
    content = obj.get('message', {}).get('content', '')
    if isinstance(content, list):
        for c in content:
            if isinstance(c, dict) and c.get('type') == 'text':
                return c.get('text', '') or ''
        return ''
    return content or ''

jsonls = []
for p in sessions_dir.rglob('*.jsonl'):
    if '/subagents/' in str(p):
        continue
    try:
        jsonls.append((p.stat().st_mtime, p))
    except OSError:
        continue
jsonls.sort(key=lambda x: -x[0])

for _, path in jsonls:
    try:
        first_user = None
        last_line = None
        with open(path, 'rb') as f:
            for raw in f:
                if raw.strip():
                    last_line = raw
                if first_user is None and b'"type":"user"' in raw:
                    first_user = raw
        if first_user is None or last_line is None:
            continue
        try:
            first = json.loads(first_user)
            last = json.loads(last_line)
        except Exception:
            continue
        cwd = first.get('cwd', '')
        if not cwd:
            continue
        branch = first.get('gitBranch', '') or ''
        ts = last.get('timestamp', '') or first.get('timestamp', '')
        text = first_user_text(first).replace('\n', ' ').strip()[:120]
        if not text:
            continue
        short_branch = branch.split('/', 1)[1] if '/' in branch else (branch or '-')
        session_id = path.stem
        meta_out.write(f'{session_id}\t{cwd}\t{path}\n')
        display_out.write(f'{fmt_ago(ts):<8}  {short_branch:<30}  {text}\n')
    except Exception:
        continue

meta_out.close()
display_out.close()
PY

if [ ! -s "$display_file" ]; then
    echo "No sessions found"
    sleep 2
    exit 1
fi

total=$(wc -l < "$display_file")

# Prepend line numbers (hidden from display via --with-nth)
numbered=$(paste -d$'\t' <(seq 1 "$total") "$display_file")

selected=$(echo "$numbered" | fzf \
    --delimiter=$'\t' \
    --with-nth=2 \
    --height=100% \
    --reverse \
    --border=rounded \
    --prompt='  ' \
    --no-sort \
    --preview="$HOME/.config/niri/scripts/claude-session-preview {1} $meta_file" \
    --preview-window=down:60%:wrap:follow \
    --bind='ctrl-d:preview-half-page-down,ctrl-u:preview-half-page-up')

[ -z "$selected" ] && exit 0

line_num=$(echo "$selected" | cut -f1)
meta_line=$(sed -n "${line_num}p" "$meta_file")
session_id=$(echo "$meta_line" | cut -f1)
cwd=$(echo "$meta_line" | cut -f2)

if [ "$ID_ONLY" = "1" ]; then
    printf '%s\n' "$session_id"
    exit 0
fi

setsid -f kitty --working-directory "$cwd" fish -c "claude --resume $session_id" >/dev/null 2>&1
exit 0
