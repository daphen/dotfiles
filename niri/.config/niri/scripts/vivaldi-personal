#!/usr/bin/env bash
# Launch or focus Vivaldi personal profile (Default). Always uses AMD iGPU.

PERSONAL_ID_FILE="/tmp/vivaldi-personal-window-id"
WORK_ID_FILE="/tmp/vivaldi-work-window-id"

# If we have a stored window ID that still exists, focus it
if [[ -f "$PERSONAL_ID_FILE" ]]; then
    stored_id=$(cat "$PERSONAL_ID_FILE")
    exists=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print('yes' if any(str(w['id']) == '$stored_id' and w.get('app_id') == 'vivaldi-stable' for w in windows) else 'no')
" 2>/dev/null)
    if [[ "$exists" == "yes" ]]; then
        niri msg action focus-window --id "$stored_id"
        exit 0
    fi
fi

# Snapshot existing vivaldi-stable IDs before launch (exclude known work window)
work_id=$(cat "$WORK_ID_FILE" 2>/dev/null || echo "")
before=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
print(' '.join(str(w['id']) for w in windows if w.get('app_id') == 'vivaldi-stable'))
" 2>/dev/null)

# Launch personal profile
/run/current-system/sw/bin/vivaldi --profile-directory=Default &

# Poll for the new vivaldi-stable window (up to 5s), excluding work profile
for i in $(seq 1 25); do
    sleep 0.2
    new_id=$(niri msg --json windows | python3 -c "
import json, sys
windows = json.load(sys.stdin)
before_ids = set('$before'.split())
work_id = '$work_id'
for w in windows:
    if w.get('app_id') == 'vivaldi-stable' and str(w['id']) not in before_ids and str(w['id']) != work_id:
        print(w['id'])
        break
" 2>/dev/null)
    if [[ -n "$new_id" ]]; then
        echo "$new_id" > "$PERSONAL_ID_FILE"
        break
    fi
done
