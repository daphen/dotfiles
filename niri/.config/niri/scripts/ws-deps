#!/usr/bin/env python3
"""
ws-deps

i3-style scratchpad for the lovable `devenv deps` singleton. Bound to
Super+Ctrl+M:

    deps on focused workspace  →  park it on `deps-stash` (hidden)
    deps elsewhere             →  bring it to the focused workspace
    no deps yet                →  spawn it (window-rule handles
                                  open-floating + initial size)

Same-output toggles preserve the window's last position, so repeat
toggles look instant. Cross-output summons re-center via niri's
move-window-to-monitor + center-window. The lag we saw before came
from niri's window-movement / window-resize animations on every move;
those are disabled in config.kdl so this script's effect is immediate.

Stateless — no ID file. niri's window list is the source of truth.
"""
from __future__ import annotations
import json
import os
import subprocess
import sys
import time
from pathlib import Path

LOVABLE_DIR = Path(os.environ["HOME"]) / "work/lovable"
STASH = "deps-stash"
APP_ID = "lovable_deps"


def niri_json(*args: str):
    out = subprocess.run(
        ["niri", "msg", "--json", *args],
        capture_output=True, text=True, timeout=2,
    )
    return json.loads(out.stdout) if out.stdout.strip() else None


def niri_action(*args: str) -> None:
    subprocess.run(
        ["niri", "msg", "action", *args],
        capture_output=True, timeout=2,
    )


def ensure_stash(workspaces: list, focused_output: str) -> None:
    """Make sure a `deps-stash` workspace exists ON the focused output.

    If it doesn't exist anywhere, name a trailing empty workspace on
    the focused output. If it exists but on the wrong output, drag it
    to the focused output via move-workspace-to-monitor — without this,
    every summon back from a different monitor is a cross-output move,
    which re-rasters kitty's process-compose grid (visible "small to
    fill up" lag) and skips position preservation (visible off-center
    on whichever monitor isn't the stash's).
    """
    existing = next((w for w in workspaces if w.get("name") == STASH), None)
    if existing is None:
        candidates = [
            w for w in workspaces
            if w.get("output") == focused_output
            and w.get("name") is None
            and w.get("active_window_id") is None
        ]
        if not candidates:
            return
        target = max(candidates, key=lambda w: w.get("idx") or 0)
        niri_action("set-workspace-name",
                    "--workspace", str(target["idx"]), STASH)
        return
    if existing.get("output") != focused_output:
        niri_action("move-workspace-to-monitor",
                    "--reference", STASH, focused_output)


def spawn_deps() -> int:
    subprocess.Popen(
        ["setsid", "kitty", "--hold", "--class", APP_ID,
         "--working-directory", str(LOVABLE_DIR),
         "-e", "direnv", "exec", ".", "devenv", "deps"],
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )
    for _ in range(60):
        time.sleep(0.15)
        for w in niri_json("windows") or []:
            if w.get("app_id") == APP_ID:
                niri_action("center-window", "--id", str(w["id"]))
                niri_action("focus-window", "--id", str(w["id"]))
                return 0
    print("ws-deps: failed to find spawned lovable_deps window",
          file=sys.stderr)
    return 1


def main() -> int:
    workspaces = niri_json("workspaces") or []
    windows = niri_json("windows") or []

    focused_ws = next((w for w in workspaces if w.get("is_focused")), None)
    if focused_ws is None:
        return 1
    focused_output = focused_ws["output"]
    # Reference for move-window-to-workspace: prefer the name (resolves
    # globally), fall back to per-output idx.
    focused_ref = focused_ws.get("name") or str(focused_ws["idx"])

    deps = next((w for w in windows if w.get("app_id") == APP_ID), None)
    if deps is None:
        return spawn_deps()

    deps_id = deps["id"]
    deps_ws_id = deps.get("workspace_id")

    if deps_ws_id == focused_ws["id"]:
        # Dismiss.
        ensure_stash(workspaces, focused_output)
        niri_action("move-window-to-workspace",
                    "--window-id", str(deps_id),
                    "--focus=false", STASH)
        return 0

    # Summon. For cross-output we line up the window's monitor first
    # (so the workspace REFERENCE resolves on the right output) and
    # then re-center, since niri's relative-position translation
    # doesn't preserve "centered". For same-output the window's last
    # position is already correct — just re-attach it.
    deps_ws = next((w for w in workspaces if w.get("id") == deps_ws_id), None)
    deps_output = deps_ws["output"] if deps_ws else focused_output

    if deps_output != focused_output:
        # Cross-output. The window-rule's min/max locks logical size to
        # 1500x850 on every monitor, so niri's auto-rescale clamps in
        # one step and kitty sees no column/row reflow.
        niri_action("move-window-to-monitor",
                    "--id", str(deps_id), focused_output)
    niri_action("move-window-to-workspace",
                "--window-id", str(deps_id),
                "--focus=false", focused_ref)
    # Always center: cheap when already centered (no-op, no animation),
    # corrects the position otherwise.
    niri_action("center-window", "--id", str(deps_id))
    niri_action("focus-window", "--id", str(deps_id))
    return 0


if __name__ == "__main__":
    sys.exit(main())
