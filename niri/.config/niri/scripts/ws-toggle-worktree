#!/usr/bin/env python3
"""
ws-toggle-worktree

Two-state toggle between `lovable-main` and the most-recent
non-main `lovable-<name>` worktree. Different worktrees are reached
via the picker (Super+Ctrl+T); Super+O just bounces between work
context and the orchestrator.

The recency list is maintained by ws-tracker (writes most-recently
focused stack to the front on every Workspace focused event).
"""
from __future__ import annotations
import json
import os
import subprocess
import sys
from pathlib import Path

RECENCY_FILE = Path(os.environ["HOME"]) / ".local/state/wt-stacks/ws/recency"
MAIN_WS = "lovable-main"


def niri_json(*args: str):
    out = subprocess.run(
        ["niri", "msg", "--json", *args], capture_output=True, text=True, timeout=2
    )
    return json.loads(out.stdout) if out.stdout.strip() else None


def main() -> int:
    workspaces = niri_json("workspaces") or []
    existing = {w.get("name") for w in workspaces if w.get("name")}
    focused_name = next(
        (w.get("name") for w in workspaces if w.get("is_focused")), None
    )

    if focused_name == MAIN_WS:
        try:
            recent = json.loads(RECENCY_FILE.read_text())
        except Exception:
            recent = []
        # Skip MAIN_WS and any vanished workspaces; first survivor wins.
        target = next(
            (n for n in recent
             if isinstance(n, str)
             and n != MAIN_WS
             and n.startswith("lovable-")
             and n in existing),
            None,
        )
        if target is None:
            return 0
    else:
        if MAIN_WS not in existing:
            return 0
        target = MAIN_WS

    subprocess.run(
        ["niri", "msg", "action", "focus-workspace", target],
        check=False, timeout=2,
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
