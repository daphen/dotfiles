#!/usr/bin/env python3
"""
wt-jump-terminal

Cycle/focus a "general-purpose" terminal kitty. Matches any kitty-class
window (plain `kitty` + our `lovable_*` stack classes) but EXCLUDES
ones that are dedicated to other keybinds:

  - devenv (term running `devenv wt` / `devenv deps` — Super+M handles)
  - claude  (any kitty with claude in its process tree — Super+G handles)

Cycles by focus_timestamp; spawns a fresh `kitty` if no candidates.
"""
from __future__ import annotations
import json
import os
import re
import subprocess
import sys

HOME = os.environ["HOME"]

KITTY_CLASS_RE = re.compile(r"^(kitty|lovable_(term|claude|nvim|deps|picker)_?.*)$")
LOVABLE_STACK_RE = re.compile(r"^lovable_(term|claude|nvim)_(.+)$")
# devenv wt and devenv deps both set process-compose titles
DEVENV_TITLE_RE = re.compile(r"^process-compose: proart/lovable")


def niri_json(*args: str):
    out = subprocess.run(
        ["niri", "msg", "--json", *args], capture_output=True, text=True, timeout=2
    )
    return json.loads(out.stdout) if out.stdout.strip() else None


def ts_tuple(w: dict) -> tuple[int, int]:
    ft = w.get("focus_timestamp") or {}
    return (ft.get("secs") or 0, ft.get("nanos") or 0)


def proc_children(pid: int) -> list[int]:
    try:
        with open(f"/proc/{pid}/task/{pid}/children") as f:
            return [int(x) for x in f.read().split() if x.isdigit()]
    except OSError:
        return []


def runs_claude(pid: int | None) -> bool:
    if not pid:
        return False
    seen: set[int] = set()
    stack = [pid]
    while stack:
        p = stack.pop()
        if p in seen:
            continue
        seen.add(p)
        try:
            with open(f"/proc/{p}/comm") as f:
                if f.read().strip() == "claude":
                    return True
        except OSError:
            continue
        stack.extend(proc_children(p))
    return False


def is_terminal_candidate(w: dict) -> bool:
    app = w.get("app_id") or ""
    if not KITTY_CLASS_RE.match(app):
        return False
    title = w.get("title") or ""
    if DEVENV_TITLE_RE.match(title):
        return False
    if runs_claude(w.get("pid")):
        return False
    return True


def lovable_workspace_id(workspaces: list[dict]) -> int | None:
    for ws in workspaces:
        if ws.get("name") == "lovable":
            return ws["id"]
    return None


def stack_name_of(w: dict) -> str | None:
    m = LOVABLE_STACK_RE.match(w.get("app_id") or "")
    return m.group(2) if m else None


def active_worktree_name(windows: list[dict], lovable_id: int | None) -> str | None:
    if lovable_id is None:
        return None
    best: tuple[tuple[int, int], str] | None = None
    for w in windows:
        if w.get("workspace_id") != lovable_id:
            continue
        name = stack_name_of(w)
        if not name:
            continue
        ts = ts_tuple(w)
        if best is None or ts > best[0]:
            best = (ts, name)
    return best[1] if best else None


def main() -> int:
    windows = niri_json("windows") or []
    workspaces = niri_json("workspaces") or []
    lovable_id = lovable_workspace_id(workspaces)
    active = active_worktree_name(windows, lovable_id)

    def allowed(w: dict) -> bool:
        if not is_terminal_candidate(w):
            return False
        if w.get("focus_timestamp") is None:
            return False
        # Off-lovable terminals are always candidates.
        if w.get("workspace_id") != lovable_id:
            return True
        # On lovable: stack-tagged kittys (lovable_term/claude/nvim_<x>)
        # are only allowed if their stack matches the active worktree.
        # Untagged on-lovable kittys (plain `kitty`, deps singleton) pass.
        name = stack_name_of(w)
        if name is None:
            return True
        return name == active

    candidates = [w for w in windows if allowed(w)]

    if not candidates:
        # No matches → spawn a fresh kitty
        subprocess.Popen(
            ["setsid", "kitty"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        return 0

    candidates.sort(key=ts_tuple, reverse=True)

    focused_id = next((w["id"] for w in windows if w.get("is_focused")), None)
    target = candidates[0]
    for i, w in enumerate(candidates):
        if w["id"] == focused_id:
            target = candidates[(i + 1) % len(candidates)]
            break

    subprocess.run(
        ["niri", "msg", "action", "focus-window", "--id", str(target["id"])],
        check=False,
        timeout=2,
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
