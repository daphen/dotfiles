[theme]
color_default = [-1, -1]
color_chat_mention = ["{{foreground.primary}}", "{{semantic.highlight_warn}}"]
color_chat_blocked = ["{{foreground.muted}}", -1]
color_chat_deleted = ["{{accent.red}}", -1]
color_chat_pending = ["{{foreground.muted}}", -1]
color_chat_selected = ["{{foreground.primary}}", "{{background.selection}}"]
color_chat_separator = ["{{foreground.muted}}", -1, "i"]
color_status_line = ["{{foreground.primary}}", "{{background.surface}}"]
color_extra_line = ["{{foreground.primary}}", "{{background.surface}}"]
color_title_line = ["{{foreground.primary}}", "{{background.surface}}"]
color_extra_window = [-1, -1]
color_prompt = ["{{accent.blue}}", -1]
color_input_line = [-1, -1]
color_input_border_insert = ["{{semantic.cursor}}", -1]
color_cursor = ["{{background.primary}}", "{{foreground.primary}}"]
color_misspelled = ["{{accent.yellow}}", -1]
color_tree_default = [-1, -1]
color_tree_selected = ["{{foreground.primary}}", "{{background.selection}}"]
color_tree_muted = ["{{foreground.muted}}", -1]
color_tree_active = ["{{foreground.primary}}", "{{background.selection}}"]
color_tree_unseen = [-1, -1, "b"]
color_tree_mentioned = ["{{accent.red}}", -1]
color_tree_active_mentioned = ["{{accent.red}}", "{{background.selection}}"]
color_format_message = [[-1, -1], ["{{foreground.muted}}", -2, 0, 0, 7], ["{{accent.blue}}", -2, 0, 8, 9], ["{{accent.blue}}", -2, 0, 19, 20]]
color_format_newline = [[-1, -1], ["{{foreground.muted}}", -2, 0, 1, 2]]
color_format_reply = [["{{foreground.muted}}", -1], ["{{accent.blue}}", -2, 0, 0, 7], ["{{accent.blue}}", -2, 0, 8, 9], ["{{accent.blue}}", -2, 0, 19, 20], [-1, -2, 0, 21, 27]]
color_format_reactions = [["{{foreground.muted}}", -1], ["{{accent.red}}", -2, 0, 0, 7], [-1, -2, 0, 23, 27]]
color_format_interaction = [["{{foreground.muted}}", -1], ["{{foreground.muted}}", -2, 0, 1, 5]]
color_format_forum = [[-1, -1], ["{{foreground.muted}}", -2, 0, 0, 12], ["{{accent.blue}}", -2, 0, 15, 20]]
color_chat_standout = ["{{accent.cyan}}", -1]
color_chat_edited = ["{{foreground.muted}}", -1]
color_chat_url = ["{{accent.blue}}", -1, "u"]
color_chat_spoiler = ["{{foreground.muted}}", -1]
color_chat_code = ["{{foreground.primary}}", "{{background.surface}}"]
