# Mako notification daemon configuration
# Generated from centralized theme system

# Font
font=monospace 11, Noto Emoji 11

# Colors
background-color={{background.primary}}D9
text-color={{foreground.primary}}
border-color={{accent.cyan}}
progress-color=over {{background.secondary}}

# Border
border-size=2
border-radius=10

# Padding
padding=15
margin=16,18,10,10

# Size
width=350
height=150

# Position (top-right)
anchor=top-right

# Timeout
default-timeout=5000
ignore-timeout=1

# Icons
icons=1
max-icon-size=48
icon-location=left

# Grouped notifications
group-by=app-name

# Appearance
layer=overlay

# Do-not-disturb mode — toggled with Super+Shift+Ctrl+D
# (`makoctl mode -t do-not-disturb`). When active, all notifications
# are auto-dismissed instantly. `invisible=1` would seem like the
# natural choice but in mako 1.11 it only suppresses group-overflow
# members, not regular notifications; `default-timeout=1` actually
# auto-dismisses (still in history, just imperceptibly brief).
[mode=do-not-disturb]
default-timeout=1

# Hide Claude Code's default "Claude is waiting for your input"
# notification. Claude Code sends notifications via kitty's OSC 99
# protocol (not notify-send) — kitty forwards them to mako, so
# app-name shows as "kitty" and summary as "Claude Code".
# The Notification hook at ~/.claude/hooks/notify-with-context.sh
# fires its own enriched version (summary "Claude · <project>")
# that doesn't match this rule, so only the custom one shows.
#
# Three mako 1.11 gotchas this rule sidesteps:
#   1. `summary` is exact-match (regex moved to `summary~`).
#   2. `invisible=1` is group-overflow only — use default-timeout=1
#      for actual suppression.
#   3. The criteria parser breaks when a quoted-value criterion
#      follows an unquoted one — backslash-escape the space instead.
[app-name=kitty summary=Claude\ Code]
default-timeout=1
