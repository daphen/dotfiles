{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 8,

  "// layout": "Notch theme. modules-center holds the entire notch contents (GTK auto-centers); modules-right holds only the floating worktree pill at the screen's far edge.",
  "modules-left": [],
  "modules-center": [
    "clock#date",
    "custom/weather",
    "cpu",
    "memory",
    "custom/niri-minimap",
    "custom/dnd",
    "network",
    "pulseaudio",
    "battery",
    "clock"
  ],
  "modules-right": ["custom/lovable-worktree"],

  "clock#date": {
    "format": "蟀儹 {:%a %b %d}",
    "tooltip": false
  },

  "clock": {
    "format": "蟀 {:%H:%M}",
    "format-alt": "蟀 {:%Y-%m-%d %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weekdays": "<span color='#a6e3a1'><b>{}</b></span>",
        "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    }
  },

  "battery": {
    "bat": "BAT1",
    "adapter": "ACAD",
    "states": { "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",
    "format-charging": "蟀倓 {capacity}%",
    "format-plugged": "蟀殽 {capacity}%",
    "format-alt": "{icon} {capacity}% {time}",
    "format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"]
  },

  "custom/weather": {
    "format": "{}",
    "interval": 900,
    "exec": "~/.config/waybar/scripts/weather.sh",
    "return-type": ""
  },

  "network": {
    "format-wifi": "蟊悑 {essid}",
    "format-ethernet": "蟊悑 {ifname}",
    "format-disconnected": "蟊悑 Disconnected",
    "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-wifi": "蟀枿 {essid} ({signalStrength}%)\n{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-ethernet": "蟀垁 {ifname}: {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "networkmanager_dmenu"
  },

  "cpu": {
    "interval": 2,
    "format": "蟀粻 {usage}%",
    "tooltip": true
  },

  "memory": {
    "interval": 5,
    "format": "蟀崨 {percentage}%",
    "tooltip-format": "RAM: {used:0.1f} / {total:0.1f} GiB ({percentage}%)\nSwap: {swapUsed:0.1f} / {swapTotal:0.1f} GiB",
    "tooltip": true,
    "states": { "warning": 75, "critical": 90 }
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "蟀偗 {volume}%",
    "format-muted": "蟀潫 {volume}%",
    "format-icons": {
      "headphone": "蟀媼",
      "hands-free": "蟀嫀",
      "headset": "蟀嫀",
      "phone": "蟀彶",
      "portable": "蟀Β",
      "car": "蟀剫",
      "default": ["蟀暱", "蟀杸", "蟀暰"]
    },
    "scroll-step": 5,
    "on-click": "~/.config/waybar/scripts/audio-menu.sh",
    "on-click-middle": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

  "custom/niri-minimap": {
    "exec": "~/.config/waybar/scripts/niri-minimap.sh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true
  },

  "custom/lovable-worktree": {
    "exec": "~/.config/waybar/scripts/lovable-worktree.sh",
    "return-type": "json",
    "format": "{}",
    "tooltip": true
  },

  "custom/dnd": {
    "exec": "~/.config/waybar/scripts/dnd-status.sh",
    "return-type": "json",
    "interval": 2,
    "format": "{}",
    "tooltip": true,
    "on-click": "makoctl mode -t do-not-disturb"
  }
}
